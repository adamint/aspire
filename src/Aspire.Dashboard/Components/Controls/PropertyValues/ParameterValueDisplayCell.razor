@using Aspire.Dashboard.Components.Controls
@using Aspire.Dashboard.Model

<ParameterValueDisplay Resource="@Resource" OnExecuteCommandAsync="@OnExecuteCommandAsync" />

@code {
    [Parameter, EditorRequired]
    public required ResourceViewModel Resource { get; set; }

    [Parameter, EditorRequired]
    public required Func<ResourceViewModel, CommandViewModel, Task> OnExecuteCommandAsync { get; set; }

    // GridValue forwards Value and HighlightText to all dynamic value components.
    // Accept and ignore them so DynamicComponent parameter binding succeeds.
    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public string? HighlightText { get; set; }
}
